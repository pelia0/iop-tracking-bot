{
    "include": [
        "."
    ],
    "exclude": [
        "__pycache__",
        ".git",
        "node_modules"
    ],
    "pythonVersion": "3.12",
    "typeCheckingMode": "basic",
    "useLibraryCodeForTypes": true,
    "reportMissingImports": "error",
    "reportMissingTypeStubs": "warning",
    "stubPath": "./stubs"
}